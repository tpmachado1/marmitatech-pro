<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>MarmitaTech - Dashboard</title>
    <link rel="stylesheet" href="/theme.css">
</head>
<body>
    <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap;">
        <div>
            <h1>Painel Administrativo - MarmitaTech</h1>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
            <a href="/admin/export" class="download-report" style="padding:0.75rem 1rem;border:none;background:#2d89ff;color:#fff;text-decoration:none;border-radius:0.35rem;font-weight:600;">Baixar Relatório</a>
            <button id="theme-toggle" aria-label="Alternar tema" class="theme-toggle">🌓</button>
        </div>
    </div>
    <div class="grid">
        <div class="card">
            <h3>Novo Item (Ingrediente)</h3>
            <form action="/add-item" method="POST">
                <input type="text" name="name" placeholder="Nome (Ex: Batata Doce)" required><br><br>
                <input type="text" name="category" placeholder="Categoria (Ex: Carboidrato)"><br><br>
                <input type="number" step="0.01" name="price" placeholder="Preço (Ex: 12.50)" required><br><br>
                <button type="submit">Cadastrar Item</button>
            </form>
        </div>

        <div class="card">
            <h3>Itens Cadastrados</h3>
            <ul>
                <% items.forEach(item => { %>
                    <li><%= item.name %> (<%= item.category %>) - R$ <%= item.price %></li>
                <% }) %>
            </ul>
        </div>
    </div>

    <hr>
    <h2>📦 Novo Pedido</h2>
    <form action="/orders" method="POST" class="inline">
        <input type="text" name="customer_name" placeholder="Nome do cliente" required>
        <select name="item_id" required>
            <% items.forEach(item => { %>
                <option value="<%= item.id %>"><%= item.name %> - R$ <%= item.price %></option>
            <% }) %>
        </select>
        <button type="submit">Criar Pedido</button>
    </form>

    <hr>
    <h2>📋 Kanban da Cozinha</h2>
    <div class="kanban">
        <% const cols = { 'Aberto': [], 'Cozinha': [], 'Entrega': [], 'Entregue': [] }; %>
        <% orders.forEach(o => { cols[o.status] = cols[o.status] || []; cols[o.status].push(o); }); %>

        <% Object.keys(cols).forEach(status => { %>
            <div class="column">
                <h3><%= status %></h3>
                <% cols[status].forEach(order => { %>
                    <div class="card-order">
                        <p><strong>#<%= order.id %></strong> - <%= order.customer_name %></p>
                        <p><em><%= order.item_name || '—' %></em></p>
                        <% if (status !== 'Entregue') { %>
                            <form action="/orders/<%= order.id %>/advance" method="POST">
                                <button type="submit">Avançar</button>
                            </form>
                        <% } %>
                    </div>
                <% }) %>
            </div>
        <% }) %>
    </div>
    <script src="/theme-toggle.js" defer></script>
</body>
</html>
