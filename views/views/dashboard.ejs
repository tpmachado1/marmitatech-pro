<!DOCTYPE html>
<html>
<head>
        <title>MarmitaTech - Dashboard</title>
        <link rel="stylesheet" href="/theme.css">
</head>
<body>
    <div class="topbar">
        <div class="brand"><div class="logo">MarmitaTech</div></div>
        <div class="search"><input placeholder="Pesquisar..."><button class="button">Buscar</button></div>
        <div class="actions"></div>
    </div>
    <div class="app-shell">
        <aside class="sidebar">
            <div class="nav-item active">Início</div>
            <div class="nav-item">Pedidos</div>
            <div class="nav-item">Itens</div>
        </aside>
        <main class="main">
            <div class="container">
                <div class="content-grid">
                    <div class="card">
                        <h3>Novo Item (Ingrediente)</h3>
                        <form action="/add-item" method="POST">
                            <input type="text" name="name" placeholder="Nome (Ex: Batata Doce)" required>
                            <input type="text" name="category" placeholder="Categoria (Ex: Carboidrato)">
                            <button type="submit" class="button">Cadastrar Item</button>
                        </form>
                    </div>
                    <div class="card">
                        <h3>Itens Cadastrados</h3>
                        <ul>
                            <% items.forEach(item => { %>
                                <li><%= item.name %> (<%= item.category %>)</li>
                            <% }) %>
                        </ul>
                    </div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
